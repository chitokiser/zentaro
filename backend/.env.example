PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

JWT_SECRET=
JWT_EXPIRES_IN=7d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# CJ Dropshipping
CJ_DROPSHIPPING_API_KEY=

# Google Sign-In (OAuth 2.0 Web application Client ID)
GOOGLE_CLIENT_ID=

# Comma-separated emails that get isAdmin:true on every login/register
ADMIN_EMAILS=

# Anthropic Claude API — powers the webzine's auto-writer (runs every 2h). Leave empty to disable.
ANTHROPIC_API_KEY=

# ZTRO QR reward event (opBNB) — see backend/contract/README.md for deployment steps.
# RELAYER_PRIVATE_KEY pays gas for every reward tx AND must be the ZtroRewardDispenser's
# `relayer` address. Generate a fresh wallet for this — never reuse a key that has ever
# been pasted into chat, committed, or shared anywhere.
OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
RELAYER_PRIVATE_KEY=
ZTRO_TOKEN_ADDRESS=0x4c88B8b5caC7F6c3F28612fe4DcCA94e76541cee
ZTRO_REWARD_CONTRACT_ADDRESS=0xe0F8e9Ce505e62aBe40E84Ac49777fF8333eE46a
# 32-byte hex (64 chars). Encrypts custodial wallet private keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=
